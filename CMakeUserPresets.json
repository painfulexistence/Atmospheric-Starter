{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Dev (Debug + compile_commands.json + ccache)",
      "description": "Local development preset — ASan disabled on macOS 26.1+ due to dyld interaction bug",
      "inherits": ["desktop"],
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS_DEBUG": "-g",
        "CMAKE_CXX_FLAGS_DEBUG": "-g"
      }
    },
    {
      "name": "rel",
      "displayName": "Release (optimized)",
      "inherits": ["desktop"],
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "rel",
      "configurePreset": "rel",
      "configuration": "Release"
    }
  ]
}
